generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String             @id @default(auto()) @map("_id") @db.ObjectId
  tenantId           String             @unique
  name               String
  address            String
  subscriptionStatus String             @default("TRIAL")
  fiscalYearStart    Int                @default(1)
  logoUrl            String?
  phone              String?
  email              String?

  // School Settings
  schoolCode         String?
  establishedYear    Int?
  motto              String?
  website            String?

  // Financial Settings
  currency           String             @default("BDT")
  currencySymbol     String             @default("৳")
  taxRate            Float              @default(0)

  // Date & Time Settings
  dateFormat         String             @default("DD/MM/YYYY")
  timeFormat         String             @default("24h")
  timezone           String             @default("Asia/Dhaka")
  firstDayOfWeek     String             @default("sunday")

  // Academic Settings
  academicYearStart  String             @default("january")
  gradingSystem      String             @default("GPA")

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users              User[]
  studentProfiles    StudentProfile[]
  academicYears      AcademicYear[]
  feeVouchers        FeeVoucher[]
  transactions       Transaction[]
  staffProfiles      StaffProfile[]
  salaryLedgers      SalaryLedger[]
  attendances        Attendance[]
  examResults        ExamResult[]
  classes            Class[]
  groups             Group[]
  sections           Section[]
  subjects           Subject[]
  exams              Exam[]
  examSubjects       ExamSubject[]
  promotionRules     PromotionRule[]
  classPromotions    ClassPromotion[]
  classSubjects      ClassSubject[]
}

model User {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String
  email          String
  name           String
  role           String       @default("CLERK")
  permissions    Json?
  hash           String
  isActive       Boolean      @default(true)
  staffProfileId String?      @db.ObjectId
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tenant         Tenant       @relation(fields: [tenantId], references: [tenantId])
  transactions   Transaction[]
  attendances    Attendance[] @relation("MarkedBy")
  decidedPromotions ClassPromotion[]
  staff          StaffProfile[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model StudentProfile {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String
  studentId       String
  rollNumber      String
  profilePictureUrl String?
  firstName       String
  lastName        String
  firstNameBn     String?
  lastNameBn      String?
  guardianName    String
  guardianContact String
  guardianEmail   String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  classId         String?    @db.ObjectId
  groupId         String?    @db.ObjectId
  sectionId       String?    @db.ObjectId
  status          String     @default("ACTIVE")
  admissionDate   DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [tenantId])
  class           Class?     @relation(fields: [classId], references: [id])
  group           Group?     @relation(fields: [groupId], references: [id])
  section         Section?   @relation(fields: [sectionId], references: [id])
  feeVouchers     FeeVoucher[]
  attendances     Attendance[]
  examResults     ExamResult[]
  promotions      ClassPromotion[]

  @@unique([tenantId, studentId])
  @@index([tenantId, rollNumber])
  @@index([tenantId, status])
  @@index([tenantId, classId])
}

model AcademicYear {
  id                       String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId                 String
  yearId                   String
  label                    String
  startDate                DateTime
  endDate                  DateTime
  isClosed                 Boolean        @default(false)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  tenant                   Tenant         @relation(fields: [tenantId], references: [tenantId])
  feeVouchers              FeeVoucher[]
  salaryLedgers            SalaryLedger[]
  examResults              ExamResult[]
  exams                    Exam[]
  promotionRules           PromotionRule[]
  fromAcademicYearPromotions ClassPromotion[] @relation("FromAcademicYearPromotions")
  toAcademicYearPromotions ClassPromotion[] @relation("ToAcademicYearPromotions")

  @@unique([tenantId, yearId])
  @@index([tenantId])
}

model FeeVoucher {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  tenantId         String
  voucherId        String
  studentProfileId String        @db.ObjectId
  academicYearId   String        @db.ObjectId
  feeType          String
  baseAmount       Float
  discountAmount   Float         @default(0)
  arrears          Float         @default(0)
  totalDue         Float
  amountPaid       Float         @default(0)
  balance          Float
  dueDate          DateTime
  status           String        @default("PENDING")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant        @relation(fields: [tenantId], references: [tenantId])
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  academicYear     AcademicYear  @relation(fields: [academicYearId], references: [id])
  transactions     Transaction[]

  @@unique([tenantId, voucherId])
  @@index([tenantId, studentProfileId])
  @@index([tenantId, status])
  @@index([dueDate])
}

model Transaction {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  transactionId String
  feeVoucherId  String     @db.ObjectId
  amountPaid    Float
  paymentMethod String
  receiptNumber String
  collectedById String     @db.ObjectId
  note          String?
  timestamp     DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [tenantId])
  feeVoucher    FeeVoucher @relation(fields: [feeVoucherId], references: [id])
  collectedBy   User       @relation(fields: [collectedById], references: [id])

  @@unique([tenantId, transactionId])
  @@index([tenantId])
  @@index([timestamp])
}

model StaffProfile {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  staffId       String
  userId        String?        @db.ObjectId
  firstName     String
  lastName      String
  firstNameBn   String?
  lastNameBn    String?
  department    String
  designation   String
  baseSalary    Float
  hireDate      DateTime
  joiningDate   DateTime?
  phone         String?
  email         String?
  gender        String?
  dateOfBirth   DateTime?
  qualification String?
  address       String?
  profilePictureUrl String?
  driveFileId   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [tenantId])
  user          User?          @relation(fields: [userId], references: [id])
  salaryLedgers SalaryLedger[]
  attendances   Attendance[]

  @@unique([tenantId, staffId])
  @@index([tenantId])
  @@index([userId])
}

model SalaryLedger {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String
  staffProfileId String       @db.ObjectId
  academicYearId String       @db.ObjectId
  month          Int
  year           Int
  baseSalary     Float
  deductions     Float        @default(0)
  advances       Float        @default(0)
  netPayable     Float
  paidAmount     Float        @default(0)
  status         String       @default("PENDING")
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tenant         Tenant       @relation(fields: [tenantId], references: [tenantId])
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@index([tenantId, staffProfileId])
  @@index([tenantId, month, year])
}

model Attendance {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  tenantId         String
  studentProfileId String?         @db.ObjectId
  staffProfileId   String?         @db.ObjectId
  date             DateTime
  status           String
  note             String?
  markedById       String          @db.ObjectId
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant           Tenant          @relation(fields: [tenantId], references: [tenantId])
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id])
  staffProfile     StaffProfile?   @relation(fields: [staffProfileId], references: [id])
  markedBy         User            @relation("MarkedBy", fields: [markedById], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, studentProfileId])
}

// Exam & Subject Models
model Subject {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  subjectId     String
  name          String
  code          String
  category      String         // "COMPULSORY", "ELECTIVE", "OPTIONAL"
  maxMarks      Float          @default(100)
  passMarks     Float          @default(33)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [tenantId])
  examResults   ExamResult[]
  examSubjects  ExamSubject[]
  classSubjects ClassSubject[]

  @@unique([tenantId, subjectId])
  @@index([tenantId])
}

// Class-Subject Mapping
model ClassSubject {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  classId       String         @db.ObjectId
  subjectId     String         @db.ObjectId
  isCompulsory  Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [tenantId])
  class         Class          @relation(fields: [classId], references: [id])
  subject       Subject        @relation(fields: [subjectId], references: [id])

  @@unique([tenantId, classId, subjectId])
  @@index([tenantId, classId])
  @@index([tenantId, subjectId])
}

model Exam {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String
  examId          String
  academicYearId  String         @db.ObjectId
  name            String         // "Mid-Term", "Final", "Unit Test"
  type            String         // "MID_TERM", "FINAL", "UNIT_TEST", "ANNUAL"
  startDate       DateTime
  endDate         DateTime
  isPublished     Boolean        @default(false)
  totalMarks      Float          @default(100)
  passPercentage  Float          @default(33)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [tenantId])
  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id])
  subjects        ExamSubject[]
  results         ExamResult[]

  @@unique([tenantId, examId])
  @@index([tenantId, academicYearId])
  @@index([tenantId, type])
}

model ExamSubject {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  examId        String         @db.ObjectId
  subjectId     String         @db.ObjectId
  maxMarks      Float
  passMarks     Float
  createdAt     DateTime       @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [tenantId])
  exam          Exam           @relation(fields: [examId], references: [id])
  subject       Subject        @relation(fields: [subjectId], references: [id])

  @@unique([tenantId, examId, subjectId])
  @@index([tenantId, examId])
  @@index([tenantId, subjectId])
}

model ExamResult {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId         String
  studentProfileId String         @db.ObjectId
  academicYearId   String         @db.ObjectId
  examId           String         @db.ObjectId
  subjectId        String         @db.ObjectId
  maxMarks         Float
  obtainedMarks    Float
  percentage       Float
  grade            String
  gradePoint       Float
  status           String         // "PASS", "FAIL", "ABSENT"
  remarks          String?
  reExamAllowed    Boolean        @default(false)
  reExamMarks      Float?
  reExamGrade      String?
  reExamStatus     String?        // "PASS", "FAIL"
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [tenantId])
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id])
  exam             Exam           @relation(fields: [examId], references: [id])
  subject          Subject        @relation(fields: [subjectId], references: [id])

  @@index([tenantId, studentProfileId])
  @@index([tenantId, examId])
  @@index([tenantId, academicYearId])
  @@unique([tenantId, studentProfileId, examId, subjectId])
}

// Promotion Models
model PromotionRule {
  id                      String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId                String
  academicYearId          String         @db.ObjectId
  classId                 String         @db.ObjectId
  minimumAttendance       Float          @default(75)
  minimumOverallPercentage Float         @default(40)
  minimumPerSubject       Float          @default(33)
  maxFailedSubjects       Int            @default(0)
  allowConditionalPromotion Boolean      @default(false)
  autoPromote             Boolean        @default(true)
  nextClassId             String?        @db.ObjectId
  isActive                Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  tenant                  Tenant         @relation(fields: [tenantId], references: [tenantId])
  academicYear            AcademicYear   @relation(fields: [academicYearId], references: [id])
  class                   Class          @relation(fields: [classId], references: [id])

  @@unique([tenantId, academicYearId, classId])
  @@index([tenantId, classId])
}

model ClassPromotion {
  id                     String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId               String
  studentProfileId       String         @db.ObjectId
  fromAcademicYearId     String         @db.ObjectId
  toAcademicYearId       String         @db.ObjectId
  fromClassId            String         @db.ObjectId
  toClassId              String         @db.ObjectId
  status                 String         // "PROMOTED", "RETAINED", "CONDITIONAL_PROMOTED"
  reason                 String?
  reExamRequired         Boolean        @default(false)
  reExamCompleted        Boolean        @default(false)
  reExamPassed           Boolean?
  decidedBy              String         @db.ObjectId
  decidedAt              DateTime       @default(now())
  createdAt              DateTime       @default(now())

  tenant                 Tenant         @relation(fields: [tenantId], references: [tenantId])
  studentProfile         StudentProfile @relation(fields: [studentProfileId], references: [id])
  fromAcademicYear       AcademicYear   @relation("FromAcademicYearPromotions", fields: [fromAcademicYearId], references: [id])
  toAcademicYear         AcademicYear   @relation("ToAcademicYearPromotions", fields: [toAcademicYearId], references: [id])
  fromClass              Class          @relation("FromClassPromotions", fields: [fromClassId], references: [id])
  toClass                Class          @relation("ToClassPromotions", fields: [toClassId], references: [id])
  decidedByUser          User           @relation(fields: [decidedBy], references: [id])

  @@index([tenantId, studentProfileId])
  @@index([tenantId, fromAcademicYearId])
  @@index([tenantId, toAcademicYearId])
}

// Add relations to existing models

// Academic Management Models
model Class {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  classId       String
  name          String
  classNumber   Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [tenantId])
  groups        Group[]
  sections      Section[]
  studentProfiles StudentProfile[]
  promotionRules           PromotionRule[]
  fromClassPromotions      ClassPromotion[] @relation("FromClassPromotions")
  toClassPromotions        ClassPromotion[] @relation("ToClassPromotions")
  classSubjects            ClassSubject[]

  @@unique([tenantId, classId])
  @@unique([tenantId, classNumber])
  @@index([tenantId])
}

model Group {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  groupId       String
  classId       String    @db.ObjectId
  name          String
  shortName     String
  subjects      String[]
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [tenantId])
  class         Class     @relation(fields: [classId], references: [id])
  sections      Section[]
  studentProfiles StudentProfile[]

  @@unique([tenantId, groupId])
  @@index([tenantId, classId])
}

model Section {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  sectionId     String
  classId       String    @db.ObjectId
  groupId       String?   @db.ObjectId
  name          String
  shortName     String
  capacity      Int?
  roomNumber    String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [tenantId])
  class         Class     @relation(fields: [classId], references: [id])
  group         Group?    @relation(fields: [groupId], references: [id])
  studentProfiles StudentProfile[]

  @@unique([tenantId, sectionId])
  @@index([tenantId, classId])
  @@index([tenantId, groupId])
}
